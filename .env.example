# Programa de Logística — variables de entorno
# Copia: cp .env.example .env.local
# Setup automático: npm run setup:all

# === Identidad del proyecto ===
MAIN_EMAIL=lasucursaldelcafe@gmail.com

# === Base de datos (local por defecto) ===
# Sin Turso: usa file:./data/logistica.db automáticamente
# TURSO_DATABASE_URL=libsql://programa-de-logistica-xxx.turso.io
# TURSO_AUTH_TOKEN=

# === Turso Platform API (crea BD + token automáticamente) ===
# Obtén en https://turso.tech/app/settings/tokens
# TURSO_PLATFORM_TOKEN=tso_...
# TURSO_ORG=empresario-virtual
# TURSO_DB_NAME=programa-de-logistica

# === Google OAuth / Identity Services (público en cliente) ===
# Mismo proyecto Google Cloud que Empresario Virtual (empresario-virtual)
# Consola: https://console.cloud.google.com/apis/credentials?project=empresario-virtual
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=
# Secreto solo para OAuth servidor (Next.js); no va al estático
GOOGLE_CLIENT_SECRET=

# === URLs de despliegue ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
GITHUB_PAGES_BASE=/Programa-de-logistca

# === Vercel (CI/CD — secrets en GitHub, no commitear) ===
# VERCEL_TOKEN=
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=
