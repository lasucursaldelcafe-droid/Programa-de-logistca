rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function role() {
      return userDoc().data.role;
    }
    function isOwnerEmail() {
      // Desbloqueo: el correo raíz opera aunque el rol en Firestore esté a medias.
      return signedIn()
        && request.auth.token.email == 'lasucursaldelcafe@gmail.com';
    }
    function isMaster() {
      // ceo / master_app (nuevos) + super_admin (legacy) + dueño del proyecto
      return isOwnerEmail()
        || (signedIn() && role() in ['ceo', 'master_app', 'super_admin']);
    }
    function isPlatformAdmin() {
      return signedIn() && role() in [
        'administrador',
        'recursos_humanos',
        'contador',
        'supervisor_sitio',
      ];
    }
    function isFinanceAdmin() {
      return signedIn() && role() in ['contador', 'administrador'];
    }
    function isHrAdmin() {
      return signedIn() && role() in ['recursos_humanos', 'administrador'];
    }
    function isAdmin() {
      return isMaster() || isPlatformAdmin();
    }
    function isSupervisor() {
      return isPlatformAdmin();
    }

    function isWorker() {
      return signedIn() && role() == 'trabajador';
    }
    function currentWorkerId() {
      return userDoc().data.workerId;
    }
    /** Empleado o supervisor de sitio con ficha de personal (misma jornada GPS). */
    function isFieldStaff() {
      return isWorker()
        || (signedIn()
          && role() == 'supervisor_sitio'
          && currentWorkerId() is string
          && currentWorkerId().size() > 0);
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isAdmin()
        || (signedIn()
          && request.auth.uid == userId
          && request.resource.data.email == request.auth.token.email
          && request.resource.data.role == 'trabajador')
        // Activación por invitación: supervisor de sitio con workerId vinculado
        || (signedIn()
          && request.auth.uid == userId
          && request.resource.data.email == request.auth.token.email
          && request.resource.data.role == 'supervisor_sitio'
          && request.resource.data.workerId is string)
        || (signedIn()
          && request.auth.uid == userId
          && request.auth.token.email == 'lasucursaldelcafe@gmail.com'
          && request.resource.data.role in ['ceo', 'administrador']
          && request.resource.data.email == request.auth.token.email);
      allow update: if isAdmin()
        || (signedIn()
          && request.auth.uid == userId
          && request.auth.token.email == 'lasucursaldelcafe@gmail.com'
          && request.resource.data.role == 'ceo'
          && request.resource.data.email == request.auth.token.email)
        || (signedIn()
          && request.auth.uid == userId
          && request.resource.data.role == resource.data.role
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['nombre', 'telefono', 'perfilCompleto']));
      allow delete: if isAdmin();
    }

    match /workers/{workerId} {
      allow read: if signedIn();
      allow create: if isAdmin() || isSupervisor();
      allow update: if isAdmin() || isSupervisor()
        || (isWorker()
          && currentWorkerId() == workerId
          && (
            (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['cuentaCreada'])
              && request.resource.data.cuentaCreada == true)
            || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['estado'])
          ));
      allow delete: if isAdmin();
    }

    match /qrCodes/{qrId} {
      // Lectura pública de QR activos: onboarding por cámara sin sesión previa
      // (la Cloud Function valida el token; esto solo permite mostrar sitio/evento).
      allow read: if resource.data.activo == true || signedIn();
      allow write: if isAdmin() || isSupervisor();
    }

    match /attendance/{attendanceId} {
      allow read: if signedIn();
      // Campo crea su propia jornada; dirección/oficina puede abrir/cerrar jornadas de otros.
      allow create: if (isFieldStaff()
          && request.resource.data.workerId == currentWorkerId())
        || isAdmin();
      allow update: if isAdmin() || isSupervisor()
        || (isFieldStaff()
          && resource.data.workerId == currentWorkerId());
      allow delete: if isAdmin();
    }

    match /consents/{consentId} {
      allow read: if signedIn()
        && (isAdmin() || isSupervisor() || resource.data.workerId == currentWorkerId());
      allow create: if isFieldStaff()
        && request.resource.data.workerId == currentWorkerId();
      allow update, delete: if isAdmin();
    }

    match /invitations/{token} {
      allow read: if true;
      allow create: if isPlatformAdmin() || isMaster();
      allow update: if isPlatformAdmin() || isMaster()
        || (signedIn()
          && resource.data.estado == 'pendiente'
          && request.resource.data.estado == 'usada'
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['estado', 'usadaEn', 'uid']));
      allow delete: if isPlatformAdmin() || isMaster();
    }

    match /events/{eventId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /sites/{siteId} {
      allow read: if signedIn();
      allow write: if isAdmin() || isSupervisor();
    }

    match /shifts/{shiftId} {
      allow read: if signedIn();
      allow create, delete: if isAdmin() || isSupervisor();
      allow update: if isAdmin() || isSupervisor()
        || (isWorker()
          && resource.data.workerId == currentWorkerId()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['estado'])
          && request.resource.data.estado in ['confirmado', 'rechazado']);
    }

    match /notifications/{notificationId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['leidaPor']);
      allow delete: if isAdmin();
    }

    match /fcmTokens/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /breaks/{breakId} {
      allow read: if signedIn();
      allow write: if isAdmin() || isSupervisor();
    }

    match /payrollRates/{rateId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /payroll/{payrollId} {
      allow read: if signedIn()
        && (isAdmin() || isSupervisor()
          || (isWorker() && resource.data.workerId == currentWorkerId()));
      allow create: if isAdmin() || isFinanceAdmin();
      allow update: if isAdmin() || isFinanceAdmin()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['estado', 'pagadoEn']);
      allow delete: if isAdmin();
    }

    match /payrollAudit/{auditId} {
      allow read: if isPlatformAdmin() || isMaster();
      allow create: if isPlatformAdmin() || isMaster();
      allow update, delete: if false;
    }

    match /setupConfig/{configId} {
      allow read: if signedIn();
      allow write: if isPlatformAdmin() || isMaster();
    }

    match /reports/{reportId} {
      allow read: if isPlatformAdmin() || isMaster()
        || (isWorker() && resource.data.workerId == currentWorkerId())
        || (signedIn()
          && role() == 'supervisor_sitio'
          && resource.data.workerId == currentWorkerId());
      // Trabajador (y supervisor de sitio con ficha) pueden crear reportes.
      allow create: if signedIn()
        && request.resource.data.workerId == currentWorkerId()
        && (isWorker()
          || (role() == 'supervisor_sitio' && currentWorkerId() is string));
      allow update: if isPlatformAdmin() || isMaster();
      allow delete: if isAdmin() || isMaster();
    }

    match /conversations/{conversationId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn();
      allow delete: if isPlatformAdmin() || isMaster();
    }

    match /messages/{messageId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn();
      allow delete: if isAdmin() || isMaster();
    }

    match /videoRooms/{roomId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn();
      allow delete: if isAdmin() || isMaster();
    }

    match /customRoles/{roleId} {
      allow read: if signedIn();
      allow write: if isMaster();
    }

    match /chatMessages/{messageId} {
      allow read: if signedIn()
        && (
          !(resource.data.channelId is string && resource.data.channelId.matches('dm-.*'))
          || (
            resource.data.participantUids is list
            && request.auth.uid in resource.data.participantUids
          )
        );
      allow create: if signedIn()
        && request.resource.data.senderUid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 2000
        && request.resource.data.channelId is string
        && request.resource.data.createdAt is string
        && (
          !("audience" in request.resource.data)
          || request.resource.data.audience == null
          || request.resource.data.audience in ["evento", "empleados", "supervisores", "directo"]
        )
        && !(
          request.resource.data.audience == "supervisores"
          && role() == "trabajador"
        )
        && (
          !(request.resource.data.channelId.matches('dm-.*'))
          || (
            request.resource.data.audience == "directo"
            && request.resource.data.participantUids is list
            && request.resource.data.participantUids.size() == 2
            && request.auth.uid in request.resource.data.participantUids
          )
        );
      allow update, delete: if isAdmin();
    }
  }
}
