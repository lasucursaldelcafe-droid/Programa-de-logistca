# Copia a apps/admin/.env.production o configura como GitHub Secrets en CI.
# Firebase Console → Configuración del proyecto → Tus apps → SDK web

VITE_DEMO_MODE=false
VITE_USE_FIREBASE_EMULATORS=false

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Opcional — notificaciones push (Cloud Messaging)
# VITE_FIREBASE_VAPID_KEY=

# Backend Google Sheets (sin JSON — npm run setup:sheets-auto)
# VITE_DATA_BACKEND=sheets
# VITE_SHEETS_WEB_APP_URL=
# VITE_SHEETS_API_TOKEN=

# Bloqueo integraciones API (ahorro tokens) — default true
# VITE_BLOQUEAR_INTEGRACIONES=true
# VITE_INTEGRACIONES_CLAVE=spe-desbloquear

# Google Maps — mapa en vivo / supervisión (Maps JavaScript API)
# VITE_GOOGLE_MAPS_API_KEY=
