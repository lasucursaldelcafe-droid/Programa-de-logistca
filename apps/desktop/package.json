{
  "name": "@spe/desktop",
  "version": "0.2.0",
  "private": true,
  "description": "Cliente Windows (Electron) — SPE Admin",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.spe.admin",
    "productName": "SPE Admin",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../admin/dist",
        "to": "web",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "artifactName": "SPE-Admin-${version}-${target}.${ext}"
    },
    "linux": {
      "target": ["AppImage"],
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
