{
  "name": "sistema-personal-eventos",
  "version": "0.2.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "functions"
  ],
  "scripts": {
    "start": "npm run dev:admin",
    "dev": "npm run dev:admin",
    "dev:full": "tsx scripts/dev-auto.ts",
    "dev:admin": "npm run dev -w @spe/admin",
    "dev:worker": "npm run dev -w @spe/worker",
    "dev:master": "npm run dev -w @spe/master",
    "dev:web": "npm run dev:admin",
    "build": "npm run build -w @spe/shared && npm run build -w @spe/admin",
    "build:all": "npm run build -w @spe/shared && npm run build -w @spe/admin && npm run build -w @spe/worker && npm run build -w @spe/master",
    "build:admin": "npm run build -w @spe/shared && npm run build -w @spe/admin",
    "build:native:admin": "npm run build -w @spe/shared && cross-env NATIVE_BUILD=true npm run build:native -w @spe/admin",
    "build:native": "npm run build -w @spe/shared && cross-env NATIVE_BUILD=true npm run build:native -w @spe/admin",
    "build:pages": "tsx scripts/ensure-production-env.ts --pages && npm run build -w @spe/shared && tsx scripts/prepare-pages.ts",
    "build:informe-pdf": "tsx scripts/generate-informe-pdf.ts",
    "build:production": "tsx scripts/ensure-production-env.ts && npm run build",
    "cap:sync": "npm run build:native && npm run cap:sync -w @spe/worker",
    "cap:android": "npm run cap:open -w @spe/worker android",
    "cap:add:android": "npm run cap:add:android -w @spe/worker",
    "electron": "npm run build:native:admin && npm run start -w @spe/desktop",
    "electron:build": "npm run build:native:admin && npm run build:win -w @spe/desktop",
    "electron:build:linux": "npm run build:native:admin && npm run build:linux -w @spe/desktop",
    "sync:links": "tsx scripts/sync-links.ts",
    "emulators": "firebase emulators:start --only auth,firestore --project demo-personal-eventos",
    "seed": "tsx scripts/seed-emulators.ts",
    "seed:production": "tsx scripts/seed-production.ts",
    "seed:sheets-production": "node scripts/seed-sheets-production.mjs",
    "setup": "tsx scripts/setup-phase1.ts",
    "setup:all": "npm run setup && npm run seed",
    "setup:auto": "tsx scripts/setup-automation.ts",
    "setup:production": "tsx scripts/setup-automation.ts -- --production",
    "setup:sheets-auto": "node scripts/setup-sheets-clasp.mjs",
    "apply:all": "node scripts/apply-all.mjs",
    "apply:all:setup": "node scripts/apply-all.mjs -- --setup",
    "sync:bootstrap": "node scripts/sync-bootstrap-from-cred.mjs",
    "config:sync": "node scripts/sync-repo-config.mjs",
    "diagnostico": "node scripts/spe-diagnostico.mjs",
    "diagnostico:fix": "node scripts/spe-cd-auto.mjs --fix",
    "cd:auto": "node scripts/spe-cd-auto.mjs --fix --deploy",
    "auto:max": "node scripts/spe-max-auto.mjs",
    "setup:cli": "node scripts/spe-setup-cli.mjs",
    "setup:cli:full": "node scripts/spe-setup-cli.mjs --full",
    "setup:cursor-key": "node scripts/push-cursor-secret.mjs",
    "setup:firebase-token": "node scripts/push-firebase-token.mjs",
    "firestore:bootstrap": "node scripts/firestore-bootstrap.mjs",
    "config:runtime": "node scripts/write-runtime-config.mjs",
    "produccion:completa": "node scripts/produccion-completa.mjs",
    "deploy:firestore-rules": "node scripts/deploy-firestore-rules-api.mjs",
    "verify:prod-login": "node scripts/verify-prod-login.mjs",
    "fix:sheets-token": "node scripts/fix-sheets-token.mjs",
    "setup:fcm": "tsx scripts/update-fcm-sw.ts",
    "firebase:deploy-rules": "firebase deploy --only firestore:rules",
    "firebase:deploy-firestore": "firebase deploy --only firestore:rules,firestore:indexes",
    "firebase:deploy-functions": "firebase deploy --only functions",
    "build:functions": "npm run build -w functions",
    "acceso": "node scripts/print-acceso.mjs",
    "test:smoke": "firebase emulators:exec --only auth,firestore --project demo-personal-eventos \"npm run seed && tsx scripts/ci-smoke.ts\"",
    "check:nav": "tsx scripts/check-nav-routes.ts",
    "verify:flows": "tsx scripts/verify-demo-flows.ts",
    "toolkit": "node scripts/run-toolkit.mjs",
    "toolkit:cli": "node scripts/run-toolkit-cli.mjs",
    "toolkit:health": "node scripts/run-toolkit-cli.mjs health",
    "toolkit:pdf": "node scripts/run-toolkit-cli.mjs pdf",
    "toolkit:setup": "node scripts/run-toolkit-cli.mjs setup",
    "toolkit:demo": "node scripts/run-toolkit-cli.mjs demo",
    "toolkit:init": "node scripts/run-toolkit-cli.mjs init",
    "toolkit:auto": "node scripts/run-toolkit-cli.mjs auto",
    "toolkit:secrets": "node scripts/run-toolkit-cli.mjs secrets",
    "pdf:informe": "npm run build:informe-pdf",
    "tutorial:capturas": "tsx scripts/capture-tutorial-screenshots.ts"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "firebase-admin": "^13.4.0",
    "firebase-tools": "^14.0.0",
    "puppeteer-core": "^25.3.0",
    "tsx": "^4.22.5",
    "typescript": "^5.8.3"
  }
}
